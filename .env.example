# 문해력 모의고사 환경변수 예시. 실제 값은 .env.local / .env.production 에.

# ── 결제 ─────────────────────────────────────────────
# 사업자등록 전까지 false. 프리미엄 오답노트 버튼은 "준비 중" 잠금 배지로 노출.
PAYMENT_ENABLED=false

# ── 광고(애드센스) ───────────────────────────────────
# 애드센스 승인 전까지 false. (루트 fineboll.com 승인 시 전 서브도메인 묶임)
NEXT_PUBLIC_ADS_ENABLED=false
NEXT_PUBLIC_ADSENSE_CLIENT=

# ── 카카오 애드핏 (회사 표준: PC 좌우 세로 레일 + 모바일 하단 배너) ──
# 애드핏에서 광고단위(DAN-...) 발급 후 넣으면 노출. 없으면 미노출.
#   PC 좌/우 = 160×600, 모바일 하단 = 320×100
NEXT_PUBLIC_ADFIT_UNIT_PC_LEFT=
NEXT_PUBLIC_ADFIT_UNIT_PC_RIGHT=
NEXT_PUBLIC_ADFIT_UNIT_MOBILE=

# ── 카카오 공유 ──────────────────────────────────────
# 카카오 JS 키 미발급 상태. 값이 없으면 공유는 링크 복사·PNG 저장만 노출.
NEXT_PUBLIC_KAKAO_JS_KEY=

# ── 사이트 ───────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://munhae.fineboll.com

# ── 계측 (analytics-spec.md, app="munhae") ───────────
# PostHog 프로젝트 키(쿠키리스 메인). 없으면 계측 비활성.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Cloudflare Web Analytics 토큰(보조). 없으면 비활성.
NEXT_PUBLIC_CF_BEACON_TOKEN=
